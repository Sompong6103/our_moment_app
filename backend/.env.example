# Environment
NODE_ENV=development
PORT=3000

# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/our_moment_db"

# JWT
JWT_ACCESS_SECRET=your_access_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Our Moment <noreply@ourmoment.app>"

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

FACEPP_API_KEY=your_facepp_api_key
FACEPP_API_SECRET=your_facepp_api_secret
FACEPP_BASE_URL=https://api-us.faceplusplus.com

# App
APP_URL=http://localhost:3000
FRONTEND_URL=ourmoment://
