generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Users ───
model User {
  id           String    @id @default(uuid())
  fullName     String    @map("full_name") @db.VarChar(120)
  email        String    @unique @db.VarChar(255)
  phoneNumber  String?   @map("phone_number") @db.VarChar(20)
  gender       Gender?
  avatarUrl    String?   @map("avatar_url") @db.Text
  passwordHash String    @map("password_hash") @db.VarChar(255)
  googleId     String?   @unique @map("google_id") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  organizedEvents Event[]         @relation("EventOrganizer")
  eventGuests     EventGuest[]
  photos          Photo[]         @relation("PhotoUploader")
  wishes          Wish[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

enum Gender {
  male
  female
  other
}

// ─── Refresh Tokens ───
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Events ───
model Event {
  id                    String      @id @default(uuid())
  organizerId           String      @map("organizer_id")
  title                 String      @db.VarChar(200)
  type                  String      @db.VarChar(50)
  description           String?     @db.Text
  dateStart             DateTime    @map("date_start")
  dateEnd               DateTime    @map("date_end")
  coverImageUrl         String?     @map("cover_image_url") @db.Text
  coverColor            String?     @map("cover_color") @db.VarChar(9)
  themeColor            String?     @map("theme_color") @db.VarChar(9)
  themeName             String?     @map("theme_name") @db.VarChar(50)
  expectedAttendeeCount Int         @default(0) @map("expected_attendee_count")
  joinCode              String      @unique @map("join_code") @db.VarChar(10)
  acceptPhotos          Boolean     @default(true) @map("accept_photos")
  status                EventStatus @default(draft)
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  deletedAt             DateTime?   @map("deleted_at")

  // Relations
  organizer     User           @relation("EventOrganizer", fields: [organizerId], references: [id])
  location      Location?
  guests        EventGuest[]
  agendaItems   AgendaItem[]
  photos        Photo[]
  wishes        Wish[]
  notifications Notification[]

  @@map("events")
}

enum EventStatus {
  draft
  published
  completed
  archived
}

// ─── Location ───
model Location {
  id        String  @id @default(uuid())
  eventId   String  @unique @map("event_id")
  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)
  address   String? @db.Text
  placeId   String? @map("place_id") @db.VarChar(100)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("locations")
}

// ─── Event Guests (join table) ───
model EventGuest {
  id             String      @id @default(uuid())
  eventId        String      @map("event_id")
  userId         String      @map("user_id")
  allergies      String?     @db.Text
  followersCount Int         @default(0) @map("followers_count")
  status         GuestStatus @default(joined)
  joinedAt       DateTime    @default(now()) @map("joined_at")
  checkedInAt    DateTime?   @map("checked_in_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_guests")
}

enum GuestStatus {
  invited
  joined
  checked_in
  left
}

// ─── Agenda Items ───
model AgendaItem {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  title       String   @db.VarChar(200)
  description String?  @db.Text
  location    String?  @db.VarChar(200)
  dateTime    DateTime @map("date_time")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("agenda_items")
}

// ─── Photos ───
model Photo {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  uploaderId String   @map("uploader_id")
  imageUrl   String   @map("image_url") @db.Text
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  deletedAt  DateTime? @map("deleted_at")

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader User  @relation("PhotoUploader", fields: [uploaderId], references: [id])

  @@map("photos")
}

// ─── Wishes ───
model Wish {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("wishes")
}

// ─── Notifications ───
model Notification {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  eventId   String?            @map("event_id")
  type      NotificationType
  title     String             @db.VarChar(200)
  message   String             @db.Text
  readAt    DateTime?          @map("read_at")
  createdAt DateTime           @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  ceremony
  reminder
  update
  offer
}
